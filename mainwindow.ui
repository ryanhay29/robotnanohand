       <property name="styleSheet">
        <string notr="true">QSlider::groove:vertical {
    border: 1px solid #bbb;
    background: transparent; /* Removes any default color from the groove */
    width: 6px;
    border-radius: 2px;
}

QSlider::add-page:vertical {
    background: green; /* Removes color from the area already traversed */
	border: 1px solid #bbb;
    border-radius: 2px;
}

QSlider::sub-page:vertical {
    background: transparent; /* Removes color from the area yet to be traversed */
    border: none;
}

QSlider::handle:vertical {
    background: grey; /* Sets the handle color to grey (no specific color) */
    border: 1px solid #aaa;
    height: 10px;
    margin: 0 -4px; /* Adjust margin to center handle in groove */
    border-radius: 4px;
}
</string>
